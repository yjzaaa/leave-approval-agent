---
title: 三层依赖方向图
config:
  theme: base
  themeVariables:
    primaryColor: "#e8e8e6"
    primaryTextColor: "#1a1a1a"
    primaryBorderColor: "#8b8b8b"
    lineColor: "#6b7280"
    fontSize: 14
---
graph TD
    Server["server/<br/>Express 路由 + SSE 桥接"]
    Agent["agent/<br/>Agent 运行时 + HITL 状态机"]
    Plugins["plugins/<br/>业务插件 (tools + prompt + api)"]
    Client["client/<br/>React 前端 UI"]
    Shared["shared/<br/>接口 + 类型 + 配置"]

    Server -->|"依赖"| Agent
    Agent -->|"依赖"| Plugins
    Plugins -->|"依赖"| Shared
    Agent -.->|"依赖"| Shared
    Client -.->|"依赖"| Shared

    Server -.-x|"❌ 不允许"| Client
    Agent -.-x|"❌ 不允许"| Server
    Plugins -.-x|"❌ 不允许"| Agent
    Shared -.-x|"❌ 无依赖"| Server

    style Server fill:#e8e8e6,stroke:#8b8b8b,color:#1a1a1a
    style Agent fill:#dbeafe,stroke:#6b7280,color:#1a1a1a
    style Plugins fill:#fef3c7,stroke:#6b7280,color:#1a1a1a
    style Client fill:#f3f3f0,stroke:#8b8b8b,color:#1a1a1a
    style Shared fill:#f0fdf4,stroke:#6b7280,color:#1a1a1a