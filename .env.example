# ─── LLM 配置 ────────────────────────────────────────
# Provider: glm-openai | glm-anthropic | deepseek | qwen | openai
LLM_PROVIDER=glm-openai
LLM_API_KEY=your-zhipu-api-key-here

# 可选：覆盖预设的 BaseURL 和模型
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-plus

# ─── 业务配置 ──────────────────────────────────────────
MAX_FORM_RETRIES=5
API_BASE_URL=
