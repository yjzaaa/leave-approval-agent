# LLM 配置 (Pi AI 统一 API)
# 支持 anthropic / openai-completions / google / mistral / bedrock
# 默认使用 anthropic (智谱 GLM 兼容)

# Anthropic 兼容 (智谱 GLM)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
PI_MODEL=glm-5-turbo

# 或者使用 OpenAI 兼容
# OPENAI_API_KEY=your-key
# PI_MODEL=openai:gpt-4o

# 业务配置
MAX_FORM_RETRIES=5
