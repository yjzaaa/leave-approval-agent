{
  "name": "leave-approval-agent",
  "version": "2.1.0",
  "description": "远程办公申请自动化审批 Agent - 基于 Pi Framework + React",
  "type": "module",
  "scripts": {
    "//": "模式: dev = local (浏览器直接运行Agent), dev:all = server (Express中转)",
    "dev": "vite",
    "dev:server": "tsx --env-file=.env src/server/index.ts",
    "dev:mlflow": "mlflow server --host 0.0.0.0 --port 5000",
    "dev:all": "concurrently \"npm run dev:server\" \"vite --mode server\"",
    "build": "vite build",
    "cli": "tsx src/server/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4",
    "@mlflow/core": "^0.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.21",
    "langfuse": "^3.38.20",
    "react": "^18.3",
    "react-dom": "^18.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "@vitejs/plugin-react": "^4.3",
    "concurrently": "^9.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19",
    "typescript": "^5.7",
    "vite": "^6.0",
    "vitest": "^3.2.4"
  }
}
